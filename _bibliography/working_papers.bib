@unpublished{wip_wurmachow_jbv,
  status={under_review},
  title={Reputation as Transformational Mechanism: A Hybrid Simulation of Micro-Macro Dynamics in Entrepreneurial Ecosystems},
  author={Wurth, Bernd and MacKenzie, Niall and Howick, Susan},
  year={2026},
  note={Previous version presented at the 85th Annual Meeting of the Academy of Management (AOM 2025).},
  abstract={Entrepreneurial ecosystem research has identified the structural conditions that foster productive entrepreneurship. However, explaining how micro-level actions aggregate into macro-level outcomes remains a fundamental challenge. We address this aggregation problem by focusing on university-firm interactions, identifying universities’ entrepreneurial reputation as a transformational mechanism that helps bridge the micro-macro divide. Reputation is inherently relational, accumulating through individual university-firm interactions, yet its consequences are systemic, reshaping partner preferences and ecosystem hierarchies. These theoretical properties create methodological demands that conventional approaches cannot meet. We develop a hybrid system dynamics agent-based simulation grounded in data from Scottish universities and UK firms that traces the complete causal pathway from micro-level exchanges to macro-level restructuring. Our findings reveal three key insights. First, the relationship between university investment and entrepreneurial ecosystem outcomes is fundamentally nonlinear; investments must reach critical thresholds before triggering self-reinforcing reputation dynamics. Second, entrepreneurial ecosystem outcomes emerge from competitive interdependencies that cannot be understood by examining individual actors in isolation. Third, entrepreneurial reputation operates as a partial substitute for research prestige for universities, enabling less research-intensive universities to improve their ecosystem position through strategic investment and repeated engagement. We contribute to microfoundational theory by specifying the mechanism of aggregation, extend resource orchestration theory to entrepreneurial ecosystem contexts where returns depend on interdependent actors, and demonstrate how hybrid simulation can operationalise multi-level theorising in complex systems.}
}

@unpublished{wip_heswurwah,
  status={working_paper},
  title={Process Velocity in New Ventures: Persistence Accelerates and Diversity Delays},
  author={Hess, Sophia and Wurth, Bernd and Wahl, Andreas},
  year={2026},
  note={Accepted for presentation and the Proceedings at the 86th Annual Meeting of the Academy of Management (AOM 2026).},
  abstract={Process velocity, defined as the rate at which ventures achieve key developmental milestones, represents a critical but understudied dimension of new venture performance. While research has established that milestone achievement predicts venture success, we know far less about what determines how quickly ventures reach these milestones. Drawing on momentum theory, dynamic states, and resource orchestration perspectives, we develop a process velocity framework examining how entrepreneurial persistence, founding team heterogeneity, and ecosystem access shape the timing of first sales, first employee hires, and first funding. Using accelerated failure time survival models on 288 new ventures, we find that persistence accelerates milestone achievement for sales and funding, with the strongest effects on funding acquisition. Team heterogeneity delays milestone achievement, particularly for sales and hiring, revealing a ‘liability of diversity’ in nascent ventures: coordination costs outweigh informational benefits before teams develop shared mental models and integrative mechanisms. Ecosystem access significantly accelerates commercialization but shows no effect on hiring or funding. We make three contributions. First, we advance a process velocity perspective that shifts attention from whether ventures achieve milestones to how quickly they achieve them. Second, we reposition persistence as a temporal capability that sustains momentum through feedback-rich early development. And third, we identify temporal boundary conditions for diversity effects that challenge assumptions of uniform benefits. These findings carry implications for team composition decisions, investor evaluation criteria, and ecosystem program design.}
}

@unpublished{wip_wurwalrom,
  status={working_paper},
  title={Closing the Loop: A Systems Theory of Entrepreneurial Action and Time},
  author={Wurth, Bernd and Walrave, Bob and Romme, Georges and Stam, Erik},
  year={2026},
  note={Accepted for presentation at the 86th Annual Meeting of the Academy of Management (AOM 2026).},
  abstract={Entrepreneurship research has long recognised that entrepreneurship unfolds through time, yet dominant theoretical frameworks remain largely static. This paper develops a dynamic systems theory of entrepreneurial action that is built on four core principles, namely feedback loops that connect goals/beliefs and decisions/actions to results and environmental responses; temporal delays that separate cause from observable effect; stock–flow accumulation processes; and non-linear dynamics including thresholds and tipping points. We demonstrate how this perspective provides a foundation for previously only loosely connected theoretical streams such as judgment-based approaches, effectuation, the theory-based view, and (entrepreneurial) ecosystems by revealing them as complementary descriptions of nested feedback systems operating at different timescales and levels of aggregation. The framework shows that entrepreneurs operate within learning loops whose effectiveness depends on delay structures; that ventures exhibit characteristic dynamic patterns emerging from underlying feedback architectures; and that ecosystems shape individual action through parameter modification. We reconceptualise external enablers as interventions that modify feedback structure (e.g., reducing delays, lowering thresholds, restructuring loops, or building stocks). Our primary contribution is demonstrating that dynamic systems thinking constitutes the missing theoretical architecture for cumulative theory building about entrepreneurship as process.}
}

@unpublished{wip_wurmachow_ejor,
  status={under_review},
  title={Capturing Emergent Behaviour in Hybrid System Dynamics Agent-Based Simulations},
  author={Wurth, Bernd and MacKenzie, Niall and Howick, Susan},
  year={2025},
  abstract={Hybrid simulations (HS) combining system dynamics (SD) and agent-based modelling (ABM) have emerged as powerful tools for studying complex systems in various domains. However, current practices often rely on simple state aggregation to link ABMs to SD modules, overlooking the richness of emergent behaviours. These emergent behaviours manifest as distinctive patterns of agent interactions and sequences of state changes over time, rather than as isolated individual states. This paper presents a novel framework for capturing and integrating such emergent behavioural patterns, which we term `behavioural signatures' (BehSig), from ABMs into the SD module in a HS, addressing a critical gap in existing HS modelling practices. We introduce three mechanisms: (1) post-simulation BehSig analysis, (2) BehSig aggregation into SD stocks, and (3) BehSig triggering model reconfiguration. This approach extends current frameworks by enabling a more nuanced representation of emergent phenomena within HS. The additional insights that this framework provides are demonstrated through a case study of university-industry collaboration, revealing behaviours of the system that commonly used HS designs cannot capture. Our approach addresses key limitations in current practices, including inadequate representation of emergent phenomena and oversimplification of agent-based dynamics. By facilitating bi-directional micro-macro feedback beyond simple state aggregation, this framework aligns with recent advancements in ABM and multi-level modelling. It contributes to operational research by enhancing hybrid SD-ABM models' capabilities to capture complex system behaviours. We discuss implementation challenges and provide implications for theory and practice, offering a foundation for more sophisticated HS across various domains in operational research.}
}

